    "# -----------------------------\n",
    "# 0️⃣ Install required libraries\n",
    "# -----------------------------\n",
    "!pip install pandas textblob\n",
    "\n",
    "# -----------------------------\n",
    "# 1️⃣ Import libraries\n",
    "# -----------------------------\n",
    "import pandas as pd\n",
    "from textblob import TextBlob\n",
    "import os\n",
    "\n",
    "# -----------------------------\n",
    "# 2️⃣ Load your Flickr CSV\n",
    "# -----------------------------\n",
    "filepath = r\"d:\\SKILLS MODULE -1\\New folder\\shoreditch_flickr_data.csv\"\n",
    "df = pd.read_csv(filepath)\n",
    "print(f\"Loaded {len(df)} posts\")\n",
    "\n",
    "# -----------------------------\n",
    "# 3️⃣ Combine text for sentiment\n",
    "# -----------------------------\n",
    "df['full_text'] = df['title'].fillna('') + ' ' + df['description'].fillna('') + ' ' + df['tags'].fillna('')\n",
    "\n",
    "# -----------------------------\n",
    "# 4️⃣ Sentiment analysis (range -2 to 2)\n",
    "# -----------------------------\n",
    "def sentiment_range(text):\n",
    "    polarity = TextBlob(text).sentiment.polarity  # -1 to 1\n",
    "    return round(polarity * 2, 2)  # scale to -2 to 2\n",
